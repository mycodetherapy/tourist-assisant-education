# Минимум для запуска: LLM_API_KEY + LLM_BASE_URL (OpenRouter)

LLM_API_KEY=sk-or-...
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4.1-mini
LLM_OPENROUTER_PROVIDERS=Azure

# Авиа API (цены, пересадки): https://www.travelpayouts.com/developers/api
# Без ключа — только deep links на агрегаторы
TRAVELPAYOUTS_API_KEY=
TRAVELPAYOUTS_MARKER=
AFFILIATE_ENABLED=true
# Admin token для GET /api/affiliate/metrics и POST /api/affiliate/sync
AFFILIATE_ADMIN_TOKEN=

# SQLite: поездки, предпочтения, версии программы
DATABASE_PATH=data/trips.db

# LangSmith (опционально): трейсы графа
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=tourist-assistant
LANGSMITH_ENDPOINT=

# LangFuse (self-hosted, опционально): трейсы через LangChain callbacks
LANGFUSE_ENABLED=false
# Локальный запуск: python3 main.py
LANGFUSE_HOST=http://localhost:3000
# Docker: docker compose run --rm app (compose подставит этот URL)
LANGFUSE_HOST_DOCKER=http://host.docker.internal:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
