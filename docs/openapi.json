  "components": {
    "schemas": {
      "AffiliateClickRequest": {
        "properties": {
          "target_url": {
            "type": "string",
            "maxLength": 2000,
            "minLength": 8,
            "title": "Target Url"
          },
          "provider": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 64
              },
              {
                "type": "null"
              }
            ],
            "title": "Provider"
          }
        },
        "type": "object",
        "required": [
          "target_url"
        ],
        "title": "AffiliateClickRequest"
      },
      "AffiliateMetricsByDate": {
        "properties": {
          "date": {
            "type": "string",
            "title": "Date"
          },
          "local_clicks": {
            "type": "integer",
            "title": "Local Clicks",
            "default": 0
          },
          "clicks": {
            "type": "integer",
            "title": "Clicks"
          },
          "bookings": {
            "type": "integer",
            "title": "Bookings"
          },
          "revenue_rub": {
            "type": "number",
            "title": "Revenue Rub"
          }
        },
        "type": "object",
        "required": [
          "date",
          "clicks",
          "bookings",
          "revenue_rub"
        ],
        "title": "AffiliateMetricsByDate"
      },
      "AffiliateMetricsByTrip": {
        "properties": {
          "trip_id": {
            "type": "integer",
            "title": "Trip Id"
          },
          "sub_id": {
            "type": "string",
            "title": "Sub Id"
          },
          "bookings": {
            "type": "integer",
            "title": "Bookings"
          },
          "revenue_rub": {
            "type": "number",
            "title": "Revenue Rub"
          }
        },
        "type": "object",
        "required": [
          "trip_id",
          "sub_id",
          "bookings",
          "revenue_rub"
        ],
        "title": "AffiliateMetricsByTrip"
      },
      "AffiliateMetricsPeriod": {
        "properties": {
          "from": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "From"
          },
          "to": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "To"
          }
        },
        "type": "object",
        "title": "AffiliateMetricsPeriod"
      },
      "AffiliateMetricsResponse": {
        "properties": {
          "period": {
            "$ref": "#/components/schemas/AffiliateMetricsPeriod"
          },
          "summary": {
            "$ref": "#/components/schemas/AffiliateMetricsSummary"
          },
          "by_date": {
            "items": {
              "$ref": "#/components/schemas/AffiliateMetricsByDate"
            },
            "type": "array",
            "title": "By Date"
          },
          "by_trip": {
            "items": {
              "$ref": "#/components/schemas/AffiliateMetricsByTrip"
            },
            "type": "array",
            "title": "By Trip"
          }
        },
        "type": "object",
        "required": [
          "period",
          "summary",
          "by_date",
          "by_trip"
        ],
        "title": "AffiliateMetricsResponse"
      },
      "AffiliateMetricsSummary": {
        "properties": {
          "trips_with_affiliate_links": {
            "type": "integer",
            "title": "Trips With Affiliate Links"
          },
          "local_clicks": {
            "type": "integer",
            "title": "Local Clicks"
          },
          "clicks": {
            "type": "integer",
            "title": "Clicks"
          },
          "bookings": {
            "type": "integer",
            "title": "Bookings"
          },
          "revenue_rub": {
            "type": "number",
            "title": "Revenue Rub"
          }
        },
        "type": "object",
        "required": [
          "trips_with_affiliate_links",
          "local_clicks",
          "clicks",
          "bookings",
          "revenue_rub"
        ],
        "title": "AffiliateMetricsSummary"
      },
      "CreateTripRequest": {
        "properties": {
          "city": {
            "type": "string",
            "title": "City"
          },
          "dates": {
            "type": "string",
            "title": "Dates"
          },
          "origin_city": {
            "type": "string",
            "title": "Origin City",
            "default": "Москва"
          },
          "user_query": {
            "type": "string",
            "title": "User Query",
            "default": "Составь культурную программу поездки"
          },
          "preferences": {
            "$ref": "#/components/schemas/TripPreferences"
          },
          "start_run": {
            "type": "boolean",
            "title": "Start Run",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "city",
          "dates",
          "preferences"
        ],
        "title": "CreateTripRequest"
      },
      "CreateTripResponse": {
        "properties": {
          "trip_id": {
            "type": "integer",
            "title": "Trip Id"
          },
          "run_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Run Id"
          }
        },
        "type": "object",
        "required": [
          "trip_id"
        ],
        "title": "CreateTripResponse"
      },
      "FinalProgram": {
        "properties": {
          "tickets": {
            "type": "string",
            "title": "Tickets",
            "description": "Билеты туда-обратно: самолёт, поезд (РЖД), автобус — со ссылками"
          },
          "routes": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/RouteProgram"
              },
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Routes",
            "description": "Три варианта маршрута на всю поездку"
          },
          "routes_text": {
            "type": "string",
            "title": "Routes Text",
            "description": "Markdown-представление маршрутов",
            "default": ""
          },
          "lifehacks": {
            "type": "string",
            "title": "Lifehacks",
            "description": "Полезные лайфхаки для туриста"
          },
          "events": {
            "type": "string",
            "title": "Events",
            "description": "Legacy: мероприятия",
            "default": ""
          },
          "dining": {
            "type": "string",
            "title": "Dining",
            "description": "Legacy: питание",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "tickets",
          "lifehacks"
        ],
        "title": "FinalProgram",
        "description": "Структурированная культурная программа поездки."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ItemFeedbackRequest": {
        "properties": {
          "version_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Version Id"
          },
          "section": {
            "type": "string",
            "enum": [
              "routes",
              "route_stops",
