    "/api/affiliate/metrics": {
      "get": {
        "tags": [
          "affiliate"
        ],
        "summary": "Affiliate Metrics",
        "description": "Сводка affiliate: exposure локально, доход из синка Travelpayouts.",
        "operationId": "affiliate_metrics_api_affiliate_metrics_get",
        "parameters": [
          {
            "name": "date_from",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "YYYY-MM-DD",
              "title": "Date From"
            },
            "description": "YYYY-MM-DD"
          },
          {
            "name": "date_to",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "YYYY-MM-DD",
              "title": "Date To"
            },
            "description": "YYYY-MM-DD"
          },
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AffiliateMetricsResponse"
